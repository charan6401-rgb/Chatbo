<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sri Charan's AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Syne:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/static/style.css"/>
</head>
<body>

  <!-- ── BACKGROUND LAYERS ── -->
  <div class="bg-canvas"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="grid-overlay"></div>

  <!-- ── TOAST ── -->
  <div class="toast" id="toast"></div>

  <!-- ── MAIN SHELL ── -->
  <div class="app-shell">

    <!-- HEADER -->
    <header class="header">
      <div class="logo-area">

        <!-- SVG Neural Logo -->
        <div class="logo-icon">
          <svg viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="logoGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#4fc3f7" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/>
              </radialGradient>
              <linearGradient id="nodeGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#4fc3f7"/>
                <stop offset="100%" stop-color="#a78bfa"/>
              </linearGradient>
              <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#4fc3f7" stop-opacity="0.5"/>
                <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.5"/>
              </linearGradient>
              <filter id="glow">
                <feGaussianBlur stdDeviation="1.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <circle cx="23" cy="23" r="22" fill="url(#logoGlow)"/>
            <rect x="1" y="1" width="44" height="44" rx="13"
              fill="rgba(10,14,35,0.7)"
              stroke="rgba(79,195,247,0.25)" stroke-width="1"/>
            <!-- Neural connections -->
            <g stroke="url(#lineGrad)" stroke-width="0.8" opacity="0.7" filter="url(#glow)">
              <line x1="23" y1="8"  x2="36" y2="18"/>
              <line x1="23" y1="8"  x2="10" y2="18"/>
              <line x1="36" y1="18" x2="36" y2="30"/>
              <line x1="10" y1="18" x2="10" y2="30"/>
              <line x1="36" y1="30" x2="23" y2="38"/>
              <line x1="10" y1="30" x2="23" y2="38"/>
              <line x1="23" y1="8"  x2="23" y2="23"/>
              <line x1="36" y1="18" x2="23" y2="23"/>
              <line x1="10" y1="18" x2="23" y2="23"/>
              <line x1="36" y1="30" x2="23" y2="23"/>
              <line x1="10" y1="30" x2="23" y2="23"/>
              <line x1="23" y1="38" x2="23" y2="23"/>
            </g>
            <!-- Nodes -->
            <g filter="url(#glow)">
              <circle cx="23" cy="8"  r="2.8" fill="url(#nodeGrad1)"/>
              <circle cx="36" cy="18" r="2.2" fill="#a78bfa"/>
              <circle cx="10" cy="18" r="2.2" fill="#4fc3f7"/>
              <circle cx="36" cy="30" r="2.2" fill="#22d3ee"/>
              <circle cx="10" cy="30" r="2.2" fill="#a78bfa"/>
              <circle cx="23" cy="38" r="2.8" fill="url(#nodeGrad1)"/>
              <!-- Pulsing center -->
              <circle cx="23" cy="23" r="4" fill="url(#nodeGrad1)" opacity="0.9">
                <animate attributeName="r" values="4;5.5;4" dur="2.5s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.9;0.6;0.9" dur="2.5s" repeatCount="indefinite"/>
              </circle>
            </g>
          </svg>
        </div>

        <div class="logo-text">
          <span class="logo-title">Sri Charan's AI</span>
          <span class="logo-sub">Neural Assistant · v2.0</span>
        </div>
      </div>

      <div class="header-right">
        <div class="status-pill">
          <div class="status-dot"></div>
          Online
        </div>
        <button class="btn-icon" id="clear-btn" title="Clear chat">
          <!-- Trash icon -->
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14H6L5 6"/>
            <path d="M10 11v6M14 11v6"/>
            <path d="M9 6V4h6v2"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- CHAT WINDOW -->
    <div class="chat-window">
      <div class="messages-area" id="messages-area">

        <!-- Empty / welcome state -->
        <div class="empty-state" id="empty-state">
          <div class="empty-icon">
            <svg width="36" height="36" viewBox="0 0 46 46" fill="none">
              <defs>
                <linearGradient id="eg" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#4fc3f7"/>
                  <stop offset="100%" stop-color="#a78bfa"/>
                </linearGradient>
              </defs>
              <circle cx="23" cy="23" r="10" stroke="url(#eg)" stroke-width="1.5" fill="none"/>
              <circle cx="23" cy="23" r="3.5" fill="url(#eg)">
                <animate attributeName="r" values="3.5;5;3.5" dur="2s" repeatCount="indefinite"/>
              </circle>
              <line x1="23" y1="8"  x2="23" y2="13" stroke="#4fc3f7" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="23" y1="33" x2="23" y2="38" stroke="#a78bfa" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="8"  y1="23" x2="13" y2="23" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="33" y1="23" x2="38" y2="23" stroke="#a78bfa" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="empty-title">Sri Charan's AI</div>
          <div class="empty-sub">
            Your intelligent companion — ask me anything about code, ideas, or the universe.
          </div>
          <div class="suggestions">
            <span class="suggestion-chip" data-text="What can you do?">What can you do?</span>
            <span class="suggestion-chip" data-text="Help me write Python code">Help me write code</span>
            <span class="suggestion-chip" data-text="Explain AI to me simply">Explain AI to me</span>
            <span class="suggestion-chip" data-text="Tell me a fun tech fact">Fun tech fact</span>
            <span class="suggestion-chip" data-text="Who is Sri Charan?">Who is Sri Charan?</span>
          </div>
        </div>

      </div>

      <!-- INPUT BAR -->
      <div class="input-bar">
        <div class="textarea-wrap">
          <textarea
            id="user-input"
            placeholder="Ask Sri Charan's AI anything…"
            rows="1"
            autocomplete="off"
            spellcheck="false"
          ></textarea>
        </div>
        <button class="send-btn" id="send-btn" title="Send message">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
    </div>

  </div><!-- /app-shell -->

  <script src="/static/script.js"></script>
</body>
</html>
